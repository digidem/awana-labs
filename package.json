    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^25.10.9",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.7.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.6.6",
    "react-router-dom": "^7.14.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
